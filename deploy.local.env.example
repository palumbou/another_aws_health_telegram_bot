# Local deploy values, sourced automatically by scripts/deploy.sh.
# Copy to deploy.local.env and fill in: that copy is gitignored, never commit it.
# Precedence: command-line options > variables already exported > this file.
#
# Do NOT put TELEGRAM_BOT_TOKEN here: pass it inline on the first deploy only
# (it is stored in Secrets Manager and kept on later deploys).

export STACK_NAME=another-aws-health-telegram-bot
export BOT_NAME=another-aws-health-telegram-bot
export ARTIFACTS_BUCKET=my-artifacts-bucket
export AWS_REGION=eu-west-1
export TELEGRAM_CHAT_ID='-100xxxxxxxxxx'
export ROUTING_RULES_FILE="$(dirname "${BASH_SOURCE[0]}")/routing.rules.local.json"
